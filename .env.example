# BTS_sec Staircase Lab
# FAKE LOCAL TEST VALUES ONLY. Do not replace these with real secrets.

POSTGRES_DB=bts_sec_lab
POSTGRES_USER=bts_lab
POSTGRES_PASSWORD=FAKE_LOCAL_POSTGRES_PASSWORD
DATABASE_URL=postgres://bts_lab:FAKE_LOCAL_POSTGRES_PASSWORD@localhost:5432/bts_sec_lab

REDIS_URL=redis://localhost:6379

MINIO_ROOT_USER=FAKE_LOCAL_MINIO_USER
MINIO_ROOT_PASSWORD=FAKE_LOCAL_MINIO_PASSWORD
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=bts-sec-lab-local

PROXY_PORT=8080

# Optional app-shell values for running the demo SaaS without Docker app containers.
API_PORT=4000
MOCK_LLM_PORT=4100
NEXT_PUBLIC_TARGET_API_BASE_URL=http://localhost:4000/api
TARGET_API_INTERNAL_URL=http://localhost:4000/api

# Optional local scanner binary for make scan. Leave blank unless BTS_sec is installed locally.
# Use `pnpm scan -- --stage <stage-id>` for deterministic scaffold reports.
BTS_SEC_BIN=
